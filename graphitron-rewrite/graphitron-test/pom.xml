<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>no.sikt</groupId>
        <artifactId>graphitron-rewrite-parent</artifactId>
        <version>10-SNAPSHOT</version>
    </parent>

    <artifactId>graphitron-test</artifactId>
    <name>${project.groupId}:${project.artifactId}</name>

    <properties>
        <outputPackage>no.sikt.graphitron.generated</outputPackage>
    </properties>

    <dependencies>
        <dependency>
            <groupId>no.sikt</groupId>
            <artifactId>graphitron-fixtures</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.jooq</groupId>
            <artifactId>jooq</artifactId>
        </dependency>
        <!-- Compile scope: generator emits sources under target/generated-sources/graphitron
             that reference graphql.schema.* and org.dataloader.* (via transitive java-dataloader),
             so these must be on the main compile classpath, not just test. -->
        <dependency>
            <!-- GeneratorDeterminismTest invokes the generator in-process against
                 the fixture schema to ratchet the three-clause contract. -->
            <groupId>no.sikt</groupId>
            <artifactId>graphitron</artifactId>
            <version>${project.version}</version>
            <scope>test</scope>
        </dependency>
        <!-- Compile scope: the federation-enabled generated GraphitronSchema.build()
             references Federation and SchemaTransformer at compile time. -->
        <dependency>
            <groupId>com.apollographql.federation</groupId>
            <artifactId>federation-graphql-java-support</artifactId>
        </dependency>
        <dependency>
            <groupId>com.graphql-java</groupId>
            <artifactId>graphql-java</artifactId>
        </dependency>

        <!-- Test dependencies -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-engine</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-params</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-postgresql</artifactId>
            <version>${version.testcontainers.postgresql}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers</artifactId>
            <version>${version.testcontainers.postgresql}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>${version.postgresql}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>ch.qos.logback</groupId>
            <artifactId>logback-classic</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <profiles>
        <!-- Connect execution tests to a pre-existing local PostgreSQL instead of TestContainers.
             Caller is responsible for running init.sql against the target database beforehand. -->
        <profile>
            <id>local-db</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <systemPropertyVariables>
                                <test.db.url>jdbc:postgresql://localhost:5432/rewrite_test</test.db.url>
                                <test.db.username>postgres</test.db.username>
                                <test.db.password>postgres</test.db.password>
                            </systemPropertyVariables>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

    <build>
        <plugins>
            <!--
                Java-17 output ratchet. Generated source files emitted into
                target/generated-sources by graphitron-maven must compile under Java 17
                syntax; consumers may be on Java 17 and cannot upgrade the language level of
                their own build. Pin the compile goal to release 17 so a Java-18+ syntax slip
                (switch patterns, sealed permits, unnamed variables, etc.) in a generator
                emitter fails this module's build rather than the consumer's.

                Tests stay at the parent's release 25 (they may use 25 features freely).
                -Werror is deliberately omitted: the parent pom sets -Xlint:all, and existing
                generated code has raw-type warnings that are a separate concern; -Werror would
                conflate "post-17 syntax leaked through" (what this ratchet is for) with
                "raw-type cleanup in the emitter" (a larger refactor).
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <executions>
                    <execution>
                        <id>default-compile</id>
                        <configuration>
                            <release>17</release>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>no.sikt</groupId>
                <artifactId>graphitron-maven</artifactId>
                <version>${project.version}</version>
                <executions>
                    <execution>
                        <id>rewrite-generate</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <schemaInputs>
                                <schemaInput>
                                    <pattern>src/main/resources/graphql/schema.graphqls</pattern>
                                </schemaInput>
                            </schemaInputs>
                            <jooqPackage>${jooqPackage}</jooqPackage>
                            <outputPackage>${outputPackage}</outputPackage>
                        </configuration>
                    </execution>
                    <!--
                        Federation-only fixture, isolated from the shared schema.graphqls so
                        federationLink stays off for the rest of the module's tests. The two
                        executions write to disjoint subpackages of target/generated-sources;
                        the orphan sweep is per-package so they don't clobber each other.
                    -->
                    <execution>
                        <id>rewrite-generate-federated</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <schemaInputs>
                                <schemaInput>
                                    <pattern>src/main/resources/graphql/federated-schema.graphqls</pattern>
                                </schemaInput>
                            </schemaInputs>
                            <jooqPackage>${jooqPackage}</jooqPackage>
                            <outputPackage>no.sikt.graphitron.generated.federated</outputPackage>
                        </configuration>
                    </execution>
                </executions>
                <dependencies>
                    <dependency>
                        <groupId>no.sikt</groupId>
                        <artifactId>graphitron-fixtures</artifactId>
                        <version>${project.version}</version>
                    </dependency>
                </dependencies>
            </plugin>
        </plugins>
    </build>
</project>
