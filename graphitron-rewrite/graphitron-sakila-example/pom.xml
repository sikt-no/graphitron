<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>no.sikt</groupId>
        <artifactId>graphitron-rewrite-parent</artifactId>
        <version>10-SNAPSHOT</version>
    </parent>

    <artifactId>graphitron-sakila-example</artifactId>
    <name>${project.groupId}:${project.artifactId}</name>

    <properties>
        <outputPackage>no.sikt.graphitron.generated</outputPackage>
        <quarkus.platform.version>3.34.5</quarkus.platform.version>
        <quarkus.platform.artifact-id>quarkus-bom</quarkus.platform.artifact-id>
        <quarkus.platform.group-id>io.quarkus</quarkus.platform.group-id>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>${quarkus.platform.group-id}</groupId>
                <artifactId>${quarkus.platform.artifact-id}</artifactId>
                <version>${quarkus.platform.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <!-- mvnpm uses npm-style version ranges, so transitive resolution can fail when
                 two graphiql 5 chains disagree (e.g. @graphiql/react wants clsx [1.2.1,2)
                 and @graphiql/plugin-doc-explorer's @react-aria chain wants [2.0.0,3)). clsx 2
                 is API-compatible with 1, so pin a single version here. -->
            <dependency>
                <groupId>org.mvnpm</groupId>
                <artifactId>clsx</artifactId>
                <version>2.1.1</version>
            </dependency>
            <!-- @graphiql/toolkit's createGraphiQLFetcher imports graphql-ws lazily for
                 subscription support. graphql-ws 6.x added Node-native server-side deps
                 (uWebSockets.js, bufferutil, utf-8-validate, node-gyp-build) that aren't on
                 Maven Central. Maven resolves version ranges before applying exclusions, so
                 a plain <exclusion> doesn't help; pinning to 5.16.0 (which only depends on
                 graphql) drops the whole subtree. The example schema has no subscriptions
                 anyway. -->
            <dependency>
                <groupId>org.mvnpm</groupId>
                <artifactId>graphql-ws</artifactId>
                <version>5.16.0</version>
            </dependency>
            <!-- @graphiql/react peer-depends on react-compiler-runtime 19.1.0-rc.1 (a React
                 19 RC), which mvnpm hasn't mirrored. The only mvnpm-published version is
                 a 1.0.0 stub. esbuild only inlines the runtime helpers @graphiql/react
                 actually uses, so the stub is sufficient. -->
            <dependency>
                <groupId>org.mvnpm</groupId>
                <artifactId>react-compiler-runtime</artifactId>
                <version>1.0.0</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <!-- Sakila jOOQ catalog. Carries init.sql onto the test classpath via main resources,
             which Testcontainers loads with .withInitScript("init.sql") in the query-to-database
             tests. -->
        <dependency>
            <groupId>no.sikt</groupId>
            <artifactId>graphitron-sakila-db</artifactId>
            <version>${project.version}</version>
        </dependency>
        <!-- Sakila services (FilmService, SampleQueryService, ...) referenced by the schema's
             @service / @externalField directives. Compile scope so the generated fetchers can
             call them at runtime; -service's compile dep on -db transitively brings the jOOQ
             catalog onto the plugin classpath via the single <plugin><dependency> below. -->
        <dependency>
            <groupId>no.sikt</groupId>
            <artifactId>graphitron-sakila-service</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.jooq</groupId>
            <artifactId>jooq</artifactId>
        </dependency>
        <!-- Compile scope: generator emits sources under target/generated-sources/graphitron
             that reference graphql.schema.* and org.dataloader.* (via transitive java-dataloader),
             so these must be on the main compile classpath, not just test. -->
        <dependency>
            <!-- GeneratorDeterminismTest invokes the generator in-process against
                 the fixture schema to ratchet the three-clause contract. -->
            <groupId>no.sikt</groupId>
            <artifactId>graphitron</artifactId>
            <version>${project.version}</version>
            <scope>test</scope>
        </dependency>
        <!-- Tier annotations (@UnitTier / @PipelineTier / @CompilationTier / @ExecutionTier)
             live in graphitron's test source root and are republished as a test-jar. -->
        <dependency>
            <groupId>no.sikt</groupId>
            <artifactId>graphitron</artifactId>
            <version>${project.version}</version>
            <type>test-jar</type>
            <classifier>tests</classifier>
            <scope>test</scope>
        </dependency>
        <!-- Compile scope: the federation-enabled generated GraphitronSchema.build()
             references Federation and SchemaTransformer at compile time. -->
        <dependency>
            <groupId>com.apollographql.federation</groupId>
            <artifactId>federation-graphql-java-support</artifactId>
        </dependency>
        <dependency>
            <groupId>com.graphql-java</groupId>
            <artifactId>graphql-java</artifactId>
        </dependency>
        <!--
            Compile scope: the generated ConstraintViolations helper and the per-fetcher
            wrapper's validator pre-step reference jakarta.validation.* (Validator,
            ConstraintViolation, Path), so the API jar must be on the main compile
            classpath. The Quarkus runtime supplies the Hibernate Validator implementation
            (and an EL impl) below, so consumers see one validation provider on the runtime
            classpath without separate hibernate-validator + expressly deps.
        -->
        <dependency>
            <groupId>jakarta.validation</groupId>
            <artifactId>jakarta.validation-api</artifactId>
        </dependency>

        <!-- Quarkus runtime: HTTP + JAX-RS, Postgres datasource, JSON
             serialization for the GraphQL endpoint, and Hibernate Validator (replaces the
             previous test-scope hibernate-validator + expressly deps). The runtime boots
             only the non-federated Graphitron via GraphqlEngine; the federated codegen
             execution stays test-only. -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-rest</artifactId>
        </dependency>
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-rest-jackson</artifactId>
        </dependency>
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-jdbc-postgresql</artifactId>
        </dependency>
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-agroal</artifactId>
        </dependency>
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-hibernate-validator</artifactId>
        </dependency>

        <!-- GraphiQL playground served at GET /graphql (when Accept: text/html). The
             web-bundler extension uses esbuild (no node toolchain) to bundle the graphiql
             5 ESM tree into a single JS+CSS pair; mvnpm packages let us declare npm deps
             as Maven artifacts. The Qute template at templates/graphiql.html renders the
             {#bundle /} tag which injects hashed asset references at runtime. -->
        <dependency>
            <groupId>io.quarkiverse.web-bundler</groupId>
            <artifactId>quarkus-web-bundler</artifactId>
            <version>2.3.1</version>
        </dependency>
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-rest-qute</artifactId>
        </dependency>
        <dependency>
            <groupId>org.mvnpm</groupId>
            <artifactId>graphiql</artifactId>
            <version>5.2.1</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.mvnpm.at.graphiql</groupId>
            <artifactId>toolkit</artifactId>
            <version>0.11.3</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.mvnpm</groupId>
            <artifactId>react</artifactId>
            <version>18.3.1</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.mvnpm</groupId>
            <artifactId>react-dom</artifactId>
            <version>18.3.1</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.mvnpm</groupId>
            <artifactId>graphql</artifactId>
            <version>16.11.0</version>
            <scope>provided</scope>
        </dependency>

        <!-- Test dependencies -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-junit5</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>io.rest-assured</groupId>
            <artifactId>rest-assured</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-engine</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-params</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-postgresql</artifactId>
            <version>${version.testcontainers.postgresql}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers</artifactId>
            <version>${version.testcontainers.postgresql}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>${version.postgresql}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>ch.qos.logback</groupId>
            <artifactId>logback-classic</artifactId>
            <scope>test</scope>
        </dependency>
        <!--
            jOOQ's Configuration exposes org.jooq.conf.Settings, a JAXB-generated class
            annotated with @XmlElement / @XmlAccessorType / @XmlType / @XmlSchemaType.
            jOOQ declares jakarta.xml.bind-api as <optional>, so it is not on the test
            classpath transitively. Without it javac cannot resolve those annotation
            methods while compiling tests that touch jOOQ types and floods the build
            with "Cannot find annotation method 'defaultValue()' in type
            'jakarta.xml.bind.annotation.XmlElement'" warnings. Pulling the API jar in
            at test scope silences them; we never need JAXB at runtime.
        -->
        <dependency>
            <groupId>jakarta.xml.bind</groupId>
            <artifactId>jakarta.xml.bind-api</artifactId>
            <version>4.0.2</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <profiles>
        <!-- Connect execution tests to a pre-existing local PostgreSQL instead of TestContainers.
             Caller is responsible for running init.sql against the target database beforehand. -->
        <profile>
            <id>local-db</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <systemPropertyVariables>
                                <test.db.url>jdbc:postgresql://localhost:5432/rewrite_test</test.db.url>
                                <test.db.username>postgres</test.db.username>
                                <test.db.password>postgres</test.db.password>
                            </systemPropertyVariables>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

    <build>
        <plugins>
            <plugin>
                <groupId>io.quarkus</groupId>
                <artifactId>quarkus-maven-plugin</artifactId>
                <version>${quarkus.platform.version}</version>
                <extensions>true</extensions>
                <executions>
                    <execution>
                        <goals>
                            <goal>build</goal>
                            <goal>generate-code</goal>
                            <goal>generate-code-tests</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <!--
                Java-17 output ratchet. Generated source files emitted into
                target/generated-sources by graphitron-maven must compile under Java 17
                syntax; consumers may be on Java 17 and cannot upgrade the language level of
                their own build. Pin the compile goal to release 17 so a Java-18+ syntax slip
                (switch patterns, sealed permits, unnamed variables, etc.) in a generator
                emitter fails this module's build rather than the consumer's.

                Tests stay at the parent's release 25 (they may use 25 features freely).
                -Werror is deliberately omitted: the parent pom sets -Xlint:all, and existing
                generated code has raw-type warnings that are a separate concern; -Werror would
                conflate "post-17 syntax leaked through" (what this ratchet is for) with
                "raw-type cleanup in the emitter" (a larger refactor).
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <executions>
                    <execution>
                        <id>default-compile</id>
                        <configuration>
                            <release>17</release>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>no.sikt</groupId>
                <artifactId>graphitron-maven</artifactId>
                <version>${project.version}</version>
                <executions>
                    <execution>
                        <id>rewrite-generate</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <schemaInputs>
                                <schemaInput>
                                    <pattern>src/main/resources/graphql/schema.graphqls</pattern>
                                </schemaInput>
                            </schemaInputs>
                            <jooqPackage>${jooqPackage}</jooqPackage>
                            <outputPackage>${outputPackage}</outputPackage>
                        </configuration>
                    </execution>
                    <!--
                        Federation-only fixture, isolated from the shared schema.graphqls so
                        federationLink stays off for the rest of the module's tests. The two
                        executions write to disjoint subpackages of target/generated-sources;
                        the orphan sweep is per-package so they don't clobber each other.
                    -->
                    <execution>
                        <id>rewrite-generate-federated</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <schemaInputs>
                                <schemaInput>
                                    <pattern>src/main/resources/graphql/federated-schema.graphqls</pattern>
                                </schemaInput>
                            </schemaInputs>
                            <jooqPackage>${jooqPackage}</jooqPackage>
                            <outputPackage>no.sikt.graphitron.generated.federated</outputPackage>
                        </configuration>
                    </execution>
                </executions>
                <dependencies>
                    <!-- Single entry: -service brings the catalog (-db) transitively via its
                         compile-scope dep, so ServiceCatalog.reflectServiceMethod can
                         Class.forName(...) the service classes and the jOOQ catalog is also
                         visible to the generator at codegen time. -->
                    <dependency>
                        <groupId>no.sikt</groupId>
                        <artifactId>graphitron-sakila-service</artifactId>
                        <version>${project.version}</version>
                    </dependency>
                </dependencies>
            </plugin>
        </plugins>
    </build>
</project>
