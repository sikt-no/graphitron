<?xml version="1.0" encoding="UTF-8"?>
<!--
  The MCP integration tests boot embedded Jetty and the SDK's Reactor-backed client. Test output
  is now redirected to target/surefire-reports/<TestClass>-output.txt (redirectTestOutputToFile in
  the parent pom), so console noise is no longer a reason to suppress logs. Keep the root at INFO so
  the captured file retains the info/warn/error context that helps diagnose a failing test; only the
  framework-internal DEBUG firehose from Jetty and Reactor is held back.
-->
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
