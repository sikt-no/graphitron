<?xml version="1.0" encoding="UTF-8"?>
<!--
  The MCP integration tests boot embedded Jetty and the SDK's Reactor-backed client; both log
  voluminously at DEBUG, which is logback's default when no config is present. Pin the root to
  WARN so the test output shows only genuine problems.
-->
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
