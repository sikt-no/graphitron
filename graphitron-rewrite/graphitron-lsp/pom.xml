<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>no.sikt</groupId>
        <artifactId>graphitron-rewrite-parent</artifactId>
        <version>10-SNAPSHOT</version>
    </parent>

    <artifactId>graphitron-lsp</artifactId>
    <name>${project.groupId}:${project.artifactId}</name>

    <properties>
        <version.lsp4j>0.24.0</version.lsp4j>
        <version.tree-sitter>0.22.6</version.tree-sitter>
        <version.tree-sitter-graphql>master-a</version.tree-sitter-graphql>
        <!--
          jtreesitter is the official FFM-based binding (JDK 23+); we are in
          the middle of swapping bonede for it (R18 Phase 6). Until the swap
          is complete this dep sits alongside bonede with no consumer code.
        -->
        <version.jtreesitter>0.26.0</version.jtreesitter>
    </properties>

    <dependencies>
        <dependency>
            <groupId>no.sikt</groupId>
            <artifactId>graphitron</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>org.eclipse.lsp4j</groupId>
            <artifactId>org.eclipse.lsp4j</artifactId>
            <version>${version.lsp4j}</version>
        </dependency>

        <dependency>
            <groupId>io.github.bonede</groupId>
            <artifactId>tree-sitter</artifactId>
            <version>${version.tree-sitter}</version>
        </dependency>
        <dependency>
            <groupId>io.github.bonede</groupId>
            <artifactId>tree-sitter-graphql</artifactId>
            <version>${version.tree-sitter-graphql}</version>
        </dependency>
        <dependency>
            <groupId>io.github.tree-sitter</groupId>
            <artifactId>jtreesitter</artifactId>
            <version>${version.jtreesitter}</version>
        </dependency>

        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>

        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>ch.qos.logback</groupId>
            <artifactId>logback-classic</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>no.sikt</groupId>
            <artifactId>graphitron-sakila-db</artifactId>
            <version>${project.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <!--
                  tree-sitter's JNI bindings write a few bytes directly to native stdout,
                  which corrupts Surefire's default stdout-based IPC channel and triggers
                  "Corrupted channel by directly writing to native stream in forked JVM".
                  Switch to TCP/IP-based fork-node IPC so the test JVM's stdout stays free
                  for the native library.

                  Phase 6 step 3 will swap the binding to jtreesitter (FFM, no JNI native
                  printf) and this workaround can be dropped together with the bonede deps.
                -->
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <forkNode implementation="org.apache.maven.plugin.surefire.extensions.SurefireForkNodeFactory"/>
                    <!--
                      jtreesitter calls SymbolLookup.libraryLookup, a restricted FFM API.
                      Without this flag JDK 25 only warns, but a future release will block
                      the call; declare the access up-front.
                    -->
                    <argLine>--enable-native-access=ALL-UNNAMED</argLine>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <profile>
            <!--
              Compiles the vendored tree-sitter runtime + tree-sitter-graphql grammar
              into a per-platform shared library under
              `target/classes/lib/<os>-<arch>/`. Phase 6 step 4 will add macOS x86_64,
              macOS arm64, and Windows x86_64 profiles alongside this one.
            -->
            <id>build-native-linux-x86_64</id>
            <activation>
                <os>
                    <family>unix</family>
                    <name>Linux</name>
                    <arch>amd64</arch>
                </os>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.5.0</version>
                        <executions>
                            <execution>
                                <id>build-tree-sitter-graphql</id>
                                <phase>generate-resources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <executable>${project.basedir}/src/main/native/build-native.sh</executable>
                                    <arguments>
                                        <argument>${project.build.outputDirectory}/lib/linux-x86_64</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

</project>
