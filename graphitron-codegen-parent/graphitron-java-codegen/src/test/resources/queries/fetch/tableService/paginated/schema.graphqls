type Query {
    customer(first: Int = 100, after: String, first_name:String): [CustomerConnection] @tableService(service: {className: "no.sikt.graphitron.codereferences.services.CustomerTableService", method: "customerTable"})
}

type Customer @table {
    id: String
}
type CustomerConnection {
    edges: [CustomerConnectionEdge]
    nodes: [Customer!]!
}

type CustomerConnectionEdge {
    cursor: String
    node: Customer
}
