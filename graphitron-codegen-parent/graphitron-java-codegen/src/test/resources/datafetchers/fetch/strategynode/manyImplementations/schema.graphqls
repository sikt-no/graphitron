type Query {
  node(id: ID!): Node # Node interface

  customer: Customer @notGenerated
  film: Film @notGenerated
  address: Address @notGenerated
}

type Customer implements Node @node @table {
  id: ID!
}

type Film implements Node @node @table {
  id: ID!
}

type Address implements Node @node @table {
  id: ID!
}
